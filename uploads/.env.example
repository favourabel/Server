EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourstore.com
EMAIL_FROM_NAME=Your Store

ALLOWED_ORIGINS=http://localhost:3000

FRONTEND_URL=http://localhost:3000